{{define "tool.go.tmpl"}}
	{{.QMCPAddTool}}(srv.SDK(), &{{.QMCPTool}}{
		Name: {{printf "%q" .ToolName}},
{{- if .Title}}
		Title: {{printf "%q" .Title}},
{{- end}}
{{- if .Description}}
		Description: {{printf "%q" .Description}},
{{- end}}
		InputSchema:  {{.InputSchemaVar}},
		OutputSchema: {{.OutputSchemaVar}},
{{- if .AnnotationsLiteral}}
		Annotations: {{.AnnotationsLiteral}},
{{- end}}
	}, func(ctx {{.QContext}}, req *{{.QMCPCallReq}}, raw {{.QJSONRaw}}) (*{{.QMCPCallResult}}, any, error) {
		var in {{.InputTypeRef}}
		if err := srv.UnmarshalProto(raw, &in); err != nil {
			return srv.FinishToolCall(ctx, req, nil, nil, {{.QFmtErrorf}}("invalid arguments: %w", err))
		}
		// Clear OUTPUT_ONLY fields: the schema hides them but the
		// wire format does not, so the upstream gRPC server must
		// never see client-supplied values for server-computed fields.
		{{.QProtomcpClearOutputOnly}}(&in)
		// ToolMiddleware may mutate &in or replace the pointer; the
		// final handler reads from g.Input so both forms propagate.
		g := &{{.QProtomcpGRPCReq}}{Input: &in, Metadata: {{.QMetadataMD}}{}}
		// Forward the MCP progress token as a gRPC metadata header so
		// downstream interceptors can correlate logs and traces.
		if tok := req.Params.GetProgressToken(); tok != nil {
			g.Metadata.Set(srv.ProgressTokenHeader(), {{.QProtomcpSanitizeMetadataValue}}({{.QFmtSprintf}}("%v", tok)))
		}
{{- if .Elicitation}}
		// Confirm with the client before making the upstream call.
		// A nil session is tolerated for unit-test harnesses.
		if req.Session != nil {
			elicitResult, elicitErr := req.Session.Elicit(ctx, &{{.Elicitation.QMCPElicitParams}}{
				Message: {{.Elicitation.MessageExpr}},
			})
			if elicitErr != nil {
				return srv.FinishToolCall(ctx, req, g, nil, elicitErr)
			}
			if elicitResult == nil || elicitResult.Action != "accept" {
				// Explicit refusal; the gRPC call does NOT run.
				return srv.FinishToolCall(ctx, req, g, &{{.QMCPCallResult}}{
					IsError: true,
					Content: []{{.QMCPContent}}{&{{.QMCPTextContent}}{Text: "User declined to proceed."}},
				}, nil)
			}
		}
{{- end}}
{{if .IsServerStreaming}}
		final := func(ctx {{.QContext}}, req *{{.QMCPCallReq}}, g *{{.QProtomcpGRPCReq}}) (*{{.QMCPCallResult}}, error) {
			ctx = {{.QMetadataNewOut}}(ctx, g.Metadata)
			upstream, ok := g.Input.(*{{.InputTypeRef}})
			if !ok {
				return nil, {{.QFmtErrorf}}("GRPCData.Input: want *%s, got %T", "{{.InputTypeRef}}", g.Input)
			}
			stream, err := {{.ClientMethod}}(ctx, upstream)
			if err != nil {
				return nil, err
			}
			var last {{.QJSONRaw}}
			var count int
			for {
				msg, rErr := stream.Recv()
				if {{.QErrorsIs}}(rErr, {{.QIOEOF}}) {
					break
				}
				if rErr != nil {
					return nil, rErr
				}
				payload, mErr := srv.MarshalProto(msg)
				if mErr != nil {
					return nil, mErr
				}
				last = {{.QJSONRaw}}(payload)
				g.Output = msg
				count++
				// Progress counter is monotonic per MCP spec. On
				// client disconnect, fall out via ctx.Err() rather
				// than burning upstream messages silently.
				if token := req.Params.GetProgressToken(); token != nil && req.Session != nil {
					if nErr := req.Session.NotifyProgress(ctx, &{{.QMCPProgressParams}}{
						ProgressToken: token,
						Progress:      float64(count),
						Message:       string(payload),
					}); nErr != nil {
						if cErr := ctx.Err(); cErr != nil {
							return nil, cErr
						}
					}
				}
			}
			// Empty stream: StructuredContent must be "{}" (not null)
			// so schema validators do not fail on a missing object.
			if count == 0 {
				return &{{.QMCPCallResult}}{
					Content:           []{{.QMCPContent}}{&{{.QMCPTextContent}}{Text: "0 messages"}},
					StructuredContent: {{.QJSONRaw}}("{}"),
				}, nil
			}
			return &{{.QMCPCallResult}}{
				Content:           []{{.QMCPContent}}{&{{.QMCPTextContent}}{Text: {{.QFmtSprintf}}("%d messages; last: %s", count, string(last))}},
				StructuredContent: last,
			}, nil
		}
{{else}}
		final := func(ctx {{.QContext}}, _ *{{.QMCPCallReq}}, g *{{.QProtomcpGRPCReq}}) (*{{.QMCPCallResult}}, error) {
			ctx = {{.QMetadataNewOut}}(ctx, g.Metadata)
			upstream, ok := g.Input.(*{{.InputTypeRef}})
			if !ok {
				return nil, {{.QFmtErrorf}}("GRPCData.Input: want *%s, got %T", "{{.InputTypeRef}}", g.Input)
			}
			resp, err := {{.ClientMethod}}(ctx, upstream)
			if err != nil {
				return nil, err
			}
			g.Output = resp
			outBytes, err := srv.MarshalProto(resp)
			if err != nil {
				return nil, err
			}
			return &{{.QMCPCallResult}}{
				Content:           []{{.QMCPContent}}{&{{.QMCPTextContent}}{Text: string(outBytes)}},
				StructuredContent: {{.QJSONRaw}}(outBytes),
			}, nil
		}
{{end}}
		result, err := srv.ToolChain(final)(ctx, req, g)
		return srv.FinishToolCall(ctx, req, g, result, err)
	})
{{end}}
